# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET_NAME=indiantranslator-documents

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS Configuration
# For multiple origins, separate with commas
# Example: https://domain1.com,https://domain2.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173,https://indian-translator-five.vercel.app
